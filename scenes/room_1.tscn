visible = false
dialogue = ["How I got here, you ask? Do not inquire, apprentice. I have my ways. >", "When I checked on Janus the Astrologist, he was trapped in a giant slime within a sea of slimes.>", "Using the best of my abilities, I sealed the slimes away. So that we can release Janus from his slimy prison, I shall now release the seal. Get ready, apprentice."]

